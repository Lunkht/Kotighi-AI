<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/imgAlertIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/bell"
        app:tint="@color/accent_red"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtAlertTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tentative d'intrusion détectée"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <TextView
            android:id="@+id/txtAlertTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Il y a 2 minutes"
            android:textSize="11sp"
            android:textColor="?attr/android:textColorSecondary"/>

    </LinearLayout>

    <com.google.android.material.chip.Chip
        android:id="@+id/chipAlertLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ÉLEVÉ"
        android:textSize="10sp"
        android:textColor="@color/accent_red"
        app:chipBackgroundColor="@color/accent_red_alpha"
        app:chipStrokeWidth="0dp"
        app:chipMinHeight="24dp"/>

</LinearLayout>
