<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     KOTIGHI AI — Layout ecran principal (dashboard)
     res/layout/activity_main.xml
     ============================================================ -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="35dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KOTIGHI AI"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.05"/>


        </LinearLayout>
        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/user"
            android:layout_gravity="center"
            app:tint="@color/accent_cyan"
            android:contentDescription="Profil" />


    </LinearLayout>

    <!-- Contenu scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Section titre -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:id="@+id/txtBienvenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenue"
                    android:textSize="17sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:fontFamily="monospace"/>
                <TextView
                    android:id="@+id/txtRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge"
                    android:paddingVertical="2dp"
                    android:text="Analyste"
                    android:textSize="11sp"
                    android:textColor="@color/accent_cyan"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tableau de bore"
                android:textSize="13sp"
                android:textColor="?attr/android:textColorSecondary"
                android:letterSpacing="0.15"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp"/>
          <!-- Metriques -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- Metric 1 -->
            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:background="@drawable/bg_card"
              android:orientation="vertical"
              android:padding="16dp"
              android:layout_marginEnd="8dp">
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 847"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/android:textColorPrimary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connexions analysées"
                android:textSize="10sp"
                android:textColor="?attr/android:textColorSecondary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+234"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"
                android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Metric 2 -->
            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:background="@drawable/bg_card"
              android:orientation="vertical"
              android:padding="16dp">
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 203"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/android:textColorPrimary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attaques bloquées"
                android:textSize="10sp"
                android:textColor="?attr/android:textColorSecondary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+18"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"
                android:layout_marginTop="4dp"/>
            </LinearLayout>

          </LinearLayout>

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- Metric 3 -->
            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:background="@drawable/bg_card"
              android:orientation="vertical"
              android:padding="16dp"
              android:layout_marginEnd="8dp">
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="452"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/android:textColorPrimary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnostics santé"
                android:textSize="10sp"
                android:textColor="?attr/android:textColorSecondary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+12"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"
                android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Metric 4 -->
            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:background="@drawable/bg_card"
              android:orientation="vertical"
              android:padding="16dp">
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="99.2%"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/android:textColorPrimary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fiabilité IA"
                android:textSize="10sp"
                android:textColor="?attr/android:textColorSecondary"/>
              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+0.1%"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"
                android:layout_marginTop="4dp"/>
            </LinearLayout>

          </LinearLayout>
          <View
            android:layout_width="match_parent"
            android:layout_height="23dp"/>
            <!-- Card Cybersecurite -->
            <LinearLayout
                android:id="@+id/cardCyber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CYBERSECURITE"
                    android:textSize="10sp"
                    android:textColor="@color/accent_cyan"
                    android:letterSpacing="0.25"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detection d'intrusion"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/android:textColorPrimary"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analysez une connexion reseau et detectez les attaques DDoS, scans de ports et brute force en temps reel."
                    android:textSize="13sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp"/>

              <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:background="@drawable/bg_tag_cyan"
                  android:paddingStart="10dp"
                  android:paddingEnd="10dp"
                  android:paddingTop="4dp"
                  android:paddingBottom="4dp"
                  android:text="Random Forest"
                  android:textSize="10sp"
                  android:textColor="@color/accent_cyan"
                  android:fontFamily="monospace"
                  android:layout_marginEnd="8dp"/>

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:background="@drawable/bg_tag_cyan"
                  android:paddingStart="10dp"
                  android:paddingEnd="10dp"
                  android:paddingTop="4dp"
                  android:paddingBottom="4dp"
                  android:text="FastAPI"
                  android:textSize="10sp"
                  android:textColor="@color/accent_cyan"
                  android:fontFamily="monospace"/>

              </LinearLayout>

            </LinearLayout>

            <!-- Card Sante -->
            <LinearLayout
                android:id="@+id/cardSante"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SANTE"
                    android:textSize="10sp"
                    android:textColor="@color/accent_health"
                    android:letterSpacing="0.25"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyse de symptomes"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/android:textColorPrimary"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selectionnez vos symptomes et obtenez un diagnostic indicatif parmi 8 diagnostics avec un score de confiance."
                    android:textSize="13sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_red"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="14 symptomes"
                        android:textSize="10sp"
                        android:textColor="@color/accent_health"
                        android:fontFamily="monospace"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_red"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="8 diagnostics"
                        android:textSize="10sp"
                        android:textColor="@color/accent_health"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="18dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageButton
                android:id="@+id/btnHistorique"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/auto_update"
                android:layout_gravity="center"
                app:tint="@color/accent_cyan"
                android:contentDescription="Historique" />

        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageButton
                android:id="@+id/btnNotification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/bell"
                android:layout_gravity="center"
                app:tint="@color/accent_cyan"
                android:contentDescription="Notifications" />

        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/fabChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/bot"
                app:tint="@color/accent_cyan"
                android:contentDescription="Assistant IA"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageButton
                android:id="@+id/settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/settings"
                android:layout_gravity="center"
                app:tint="@color/accent_cyan"
                android:contentDescription="Paramètres" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
