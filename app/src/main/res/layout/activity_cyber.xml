<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginTop="28dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/colorOnBackground"
            android:layout_alignParentStart="true"
            android:contentDescription="Retour" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Module Cybersécurité"
            android:textSize="18sp"
            android:layout_centerInParent="true"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginStart="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tag_cyan"
            android:paddingHorizontal="12dp"
            android:layout_alignParentEnd="true"
            android:paddingVertical="4dp"
            android:text="CYBER"
            android:textSize="10sp"
            android:textColor="@color/accent_cyan"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"/>

        <ImageButton
            android:id="@+id/btnSwitchToModern"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/auto_update"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/accent_cyan"
            android:layout_toStartOf="@id/btnBack"
            android:layout_marginEnd="8dp"
            android:contentDescription="Interface Moderne" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="24dp"
                android:padding="4dp">

                <Button
                    android:id="@+id/tabScan"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="SCAN"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_primary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <Button
                    android:id="@+id/tabSurveillance"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="SURVEILLANCE"
                    android:textSize="12sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:background="@android:color/transparent"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>

            <!-- CONTAINER SCAN -->
            <LinearLayout
                android:id="@+id/containerScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CIBLES D'ANALYSE"
                    android:textSize="10sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp"/>

                <!-- Input IP Manuelle -->
                <EditText
                    android:id="@+id/editIpInput"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:hint="Saisir IP cible (ex: 192.168.1.10)"
                    android:textColor="?attr/android:textColorPrimary"
                    android:textColorHint="?attr/android:textColorSecondary"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnAjouterIp"
                        style="@style/Widget.KotighiAI.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="+ AJOUTER"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnRetirerIp"
                        style="@style/Widget.KotighiAI.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="- RETIRER"
                        app:backgroundTint="@color/accent_purple"
                        android:textSize="12sp"/>

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerIps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:layout_marginBottom="24dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorControlNormal"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARAMÈTRES DE SIMULATION"
                    android:textSize="10sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Req/min"
                            android:textSize="11sp"
                            android:textColor="?attr/android:textColorSecondary"
                            android:layout_marginBottom="6dp"/>
                        <EditText
                            android:id="@+id/editRequetes"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="12dp"
                            android:text="150"
                            android:textColor="?attr/android:textColorPrimary"
                            android:textSize="13sp"
                            android:inputType="number"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ports"
                            android:textSize="11sp"
                            android:textColor="?attr/android:textColorSecondary"
                            android:layout_marginBottom="6dp"/>
                        <EditText
                            android:id="@+id/editPorts"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="12dp"
                            android:text="5"
                            android:textColor="?attr/android:textColorPrimary"
                            android:textSize="13sp"
                            android:inputType="number"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Erreur"
                            android:textSize="11sp"
                            android:textColor="?attr/android:textColorSecondary"
                            android:layout_marginBottom="6dp"/>
                        <EditText
                            android:id="@+id/editErreur"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="12dp"
                            android:text="0.01"
                            android:textColor="?attr/android:textColorPrimary"
                            android:textSize="13sp"
                            android:inputType="numberDecimal"/>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLancerScan"
                        style="@style/Widget.KotighiAI.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SCAN RÉSEAU"
                        app:backgroundTint="@color/accent_purple"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnAjouterSurveillance"
                        style="@style/Widget.KotighiAI.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SURVEILLER"
                        app:backgroundTint="@color/accent_cyan"/>

                </LinearLayout>

                <!-- Premium Progress Layout -->
                <LinearLayout
                    android:id="@+id/layoutProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp">

                    <ProgressBar
                        android:id="@+id/progressBarHorizontal"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_progress_horizontal"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/txtProgressStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Initialisation du scan..."
                        android:textColor="?attr/android:textColorSecondary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtResultat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"/>
            </LinearLayout>

            <!-- CONTAINER SURVEILLANCE -->
            <LinearLayout
                android:id="@+id/containerSurveillance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SURVEILLANCE ACTIVE"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/android:textColorPrimary"
                    android:layout_marginBottom="16dp"/>

                <!-- Metriques Surveillance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cibles"
                            android:textSize="11sp"
                            android:textColor="?attr/android:textColorSecondary"/>
                        <TextView
                            android:id="@+id/txtSurvCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="?attr/android:textColorPrimary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alertes"
                            android:textSize="11sp"
                            android:textColor="?attr/android:textColorSecondary"/>
                        <TextView
                            android:id="@+id/txtSurvAlerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_red"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trafic"
                            android:textSize="11sp"
                            android:textColor="?attr/android:textColorSecondary"/>
                        <TextView
                            android:id="@+id/txtSurvTraffic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Mbps"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_cyan"/>
                    </LinearLayout>

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerSurveillance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Log Events -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOGS D'ÉVÉNEMENTS"
                    android:textSize="10sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txtEventsLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:text="Aucun événement..."
                    android:textColor="?attr/android:textColorSecondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="24dp"/>

                <!-- System Resources -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESSOURCES SYSTÈME"
                    android:textSize="10sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utilisation CPU"
                    android:textSize="11sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:layout_marginBottom="4dp"/>
                <ProgressBar
                    android:id="@+id/progressCpu"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="0"
                    android:layout_marginBottom="16dp"
                    android:progressTint="@color/accent_purple"
                    android:progressBackgroundTint="?attr/colorControlNormal"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utilisation RAM"
                    android:textSize="11sp"
                    android:textColor="?attr/android:textColorSecondary"
                    android:layout_marginBottom="4dp"/>
                <ProgressBar
                    android:id="@+id/progressRam"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="0"
                    android:layout_marginBottom="32dp"
                    android:progressTint="@color/accent_cyan"
                    android:progressBackgroundTint="?attr/colorControlNormal"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
