# ============================================================
#  KOTIGHI AI - Configuration Environnement
#  Copier ce fichier en .env et remplir avec vos valeurs
# ============================================================

# --- BASE DE DONNÉES ---
# SQLite (développement local)
# DATABASE_URL=sqlite:///./kotighi.db

# Supabase PostgreSQL (recommandé)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.izeukppgxagzvwfhiqra.supabase.co:5432/postgres

# Supabase Configuration
SUPABASE_URL=https://izeukppgxagzvwfhiqra.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# --- SÉCURITÉ JWT ---
# Générer une clé secrète forte : openssl rand -hex 32
SECRET_KEY=changez_cette_cle_secrete_en_production_utilisez_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- API CONFIGURATION ---
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- CORS (si nécessaire) ---
ALLOWED_ORIGINS=http://localhost:3000,https://votre-frontend.com

# --- LOGGING ---
LOG_LEVEL=INFO

# --- MODÈLES ML ---
# Chemins vers les modèles (relatifs au dossier Kotighi-AI/)
MODEL_CYBER_PATH=model_cyber.pkl
SCALER_CYBER_PATH=scaler_cyber.pkl
MODEL_SANTE_PATH=model_sante.pkl
LABELS_SANTE_PATH=labels_sante.pkl
CONSEILS_SANTE_PATH=conseils_sante.pkl

# --- LIMITES API ---
MAX_REQUESTS_PER_MINUTE=60
MAX_HISTORY_ITEMS=100

# --- EMAIL (optionnel - pour notifications) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASSWORD=votre-mot-de-passe-app
# SMTP_FROM=noreply@kotighi.ai
